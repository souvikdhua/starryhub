# Server Configuration
PORT=3000
REDIS_URL=redis://localhost:6379/0

# API Keys
# Google Maps Platform (Required for StreetView and Places)
GOOGLE_MAPS_API_KEY=

# TomTom or HERE Traffic (Optional for live traffic)
TRAFFIC_API_KEY=

# OpenWeatherMap (Optional for weather overlay)
OPENWEATHERMAP_API_KEY=

# Cesium Ion (Optional if using default token is insufficient)
CESIUM_ION_TOKEN=
